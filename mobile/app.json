{
  "expo": {
    "name": "Doce",
    "slug": "doce",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/doce-app-icon.png",
    "scheme": "doce",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.zamiasorganization.doce"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/images/doce-icon-transparent.png",
        "monochromeImage": "./assets/images/doce-icon-transparent.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.zamiasorganization.doce"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/doce-icon-transparent.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/doce-app-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0d49d1b2-fd06-4ecc-82b3-6ea9969f0d28"
      }
    },
    "owner": "zam-ias-organization",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/0d49d1b2-fd06-4ecc-82b3-6ea9969f0d28"
    }
  }
}
